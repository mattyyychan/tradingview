# Path to your Google OAuth credentials JSON file downloaded from Google Cloud Console
GOOGLE_CREDENTIALS_FILE=credentials.json

# Gmail search query (optional, default fetches recent emails)
GMAIL_QUERY=is:unread

# Maximum number of emails to fetch per run
GMAIL_MAX_RESULTS=10

# Google Sheets spreadsheet ID (found in the sheet URL)
# Example: https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
SPREADSHEET_ID=your_spreadsheet_id_here

# Sheet name / tab to write to
SHEET_NAME=Sheet1
